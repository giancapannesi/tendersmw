---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Procurement Guides | TendersMW"
  description="Learn how to bid on tenders in Malawi. Guides on PPDA procurement, tender preparation, and winning government contracts."
>
  <section class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <h1 class="text-3xl font-bold text-text mb-2">Procurement Guides</h1>
    <p class="text-muted mb-8">Learn how to find, prepare for, and win tenders in Malawi</p>

    <div class="glass-card p-12 text-center">
      <svg xmlns="http://www.w3.org/2000/svg" class="mx-auto h-12 w-12 text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25"/>
      </svg>
      <h3 class="mt-4 text-lg font-semibold text-text">Guides Coming Soon</h3>
      <p class="mt-2 text-sm text-muted max-w-md mx-auto">
        We're preparing comprehensive guides on procurement in Malawi, including how to register as a supplier, prepare tender documents, and navigate the PPDA process.
      </p>
    </div>
  </section>
</BaseLayout>
