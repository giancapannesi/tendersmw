---
import BaseLayout from '../../layouts/BaseLayout.astro';

const guides = [
  {
    title: 'How to Bid on Government Tenders in Malawi',
    description: 'Step-by-step guide covering supplier registration, tender documents, bid preparation, submission, evaluation, and winning strategies.',
    href: '/guides/how-to-bid-on-tenders-in-malawi/',
    icon: '📋',
    readTime: '15 min read',
  },
  {
    title: 'PPDA Procurement Guide',
    description: 'Everything you need to know about the PPDA — registration process, categories, fees, compliance requirements, complaints, and MANEPS.',
    href: '/guides/ppda-procurement-guide/',
    icon: '🏛️',
    readTime: '12 min read',
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Procurement Guides — TendersMW',
  description: 'Learn how to bid on tenders in Malawi. Comprehensive guides on PPDA procurement, tender preparation, and winning government contracts.',
  url: 'https://tendersmw.com/guides/',
  breadcrumb: {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://tendersmw.com/' },
      { '@type': 'ListItem', position: 2, name: 'Guides' },
    ],
  },
};
---

<BaseLayout
  title="Procurement Guides | TendersMW"
  description="Learn how to bid on tenders in Malawi. Guides on PPDA procurement, tender preparation, and winning government contracts."
  jsonLd={jsonLd}
>
  <section class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <h1 class="text-3xl font-bold text-text mb-2">Procurement Guides</h1>
    <p class="text-muted mb-8">Learn how to find, prepare for, and win tenders in Malawi</p>

    <div class="grid gap-6 sm:grid-cols-2">
      {guides.map(guide => (
        <a href={guide.href} class="glass-card p-6 hover:border-primary/30 transition-colors group">
          <div class="flex items-start gap-4">
            <span class="text-3xl">{guide.icon}</span>
            <div>
              <h2 class="text-lg font-semibold text-text group-hover:text-primary transition-colors mb-2">{guide.title}</h2>
              <p class="text-sm text-muted leading-relaxed mb-3">{guide.description}</p>
              <span class="text-xs text-muted">{guide.readTime}</span>
            </div>
          </div>
        </a>
      ))}
    </div>

    <!-- Coming Soon -->
    <div class="mt-10">
      <h2 class="text-lg font-semibold text-text mb-4">More Guides Coming Soon</h2>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        <div class="glass-card p-4 opacity-60">
          <h3 class="text-sm font-medium text-text mb-1">MANEPS Registration Guide</h3>
          <p class="text-xs text-muted">How to register and use Malawi's new electronic procurement system.</p>
        </div>
        <div class="glass-card p-4 opacity-60">
          <h3 class="text-sm font-medium text-text mb-1">Construction Tenders Guide</h3>
          <p class="text-xs text-muted">NCA registration, bonding requirements, and bidding on construction works.</p>
        </div>
        <div class="glass-card p-4 opacity-60">
          <h3 class="text-sm font-medium text-text mb-1">Donor-Funded Tenders</h3>
          <p class="text-xs text-muted">World Bank, EU, and AfDB procurement rules for Malawi projects.</p>
        </div>
        <div class="glass-card p-4 opacity-60">
          <h3 class="text-sm font-medium text-text mb-1">Tender Document Checklist</h3>
          <p class="text-xs text-muted">Complete checklist of documents needed for different tender types.</p>
        </div>
        <div class="glass-card p-4 opacity-60">
          <h3 class="text-sm font-medium text-text mb-1">MSME Preferences Guide</h3>
          <p class="text-xs text-muted">Your rights as an MSME under the 2020 Preference Order.</p>
        </div>
        <div class="glass-card p-4 opacity-60">
          <h3 class="text-sm font-medium text-text mb-1">Procurement Glossary</h3>
          <p class="text-xs text-muted">Key terms and definitions used in Malawi public procurement.</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
