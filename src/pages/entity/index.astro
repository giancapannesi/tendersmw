---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getUniqueEntities } from '../../utils/data';

const entities = getUniqueEntities();
---

<BaseLayout
  title="Procuring Entities | TendersMW"
  description="Browse tenders by procuring entity — government ministries, parastatals, development organizations, and more."
>
  <section class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <h1 class="text-3xl font-bold text-text mb-2">Procuring Entities</h1>
    <p class="text-muted mb-8">Organizations that have issued procurement notices</p>

    {entities.length > 0 ? (
      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
        {entities.map(entity => (
          <a href={`/entity/${entity.slug}/`} class="glass-card p-4 flex items-center justify-between">
            <span class="text-sm font-medium text-text">{entity.name}</span>
            <span class="inline-flex items-center rounded-full bg-primary-light px-2 py-0.5 text-xs font-medium text-primary">
              {entity.count}
            </span>
          </a>
        ))}
      </div>
    ) : (
      <div class="glass-card p-12 text-center">
        <p class="text-muted">No entities yet. Tenders will be aggregated soon.</p>
      </div>
    )}
  </section>
</BaseLayout>
