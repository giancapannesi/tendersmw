---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CategoryCard from '../../components/CategoryCard.astro';
import { getCategories } from '../../utils/data';

const categories = getCategories();
---

<BaseLayout
  title="Browse Tenders by Category | TendersMW"
  description="Find Malawi tenders by category: goods, construction, consulting, IT, health, agriculture, energy, and more."
>
  <section class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <h1 class="text-3xl font-bold text-text mb-2">Tender Categories</h1>
    <p class="text-muted mb-8">Browse procurement opportunities by type</p>

    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {categories.map(cat => (
        <CategoryCard
          name={cat.name}
          slug={cat.slug}
          description={cat.description}
          icon={cat.icon}
          count={cat.count}
        />
      ))}
    </div>
  </section>
</BaseLayout>
