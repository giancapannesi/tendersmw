---
import type { Tender } from '../utils/data';
import { formatDate } from '../utils/data';

interface Props {
  tender: Tender;
}

const { tender } = Astro.props;

const statusClass = tender.status === 'open' ? 'status-open' :
                    tender.status === 'closing_soon' ? 'status-closing' :
                    'status-closed';

const statusLabel = tender.status === 'open' ? 'Open' :
                    tender.status === 'closing_soon' ? `${tender.days_remaining}d left` :
                    'Closed';

const sourceNames: Record<string, string> = {
  ppda: 'PPDA',
  maneps: 'MANEPS',
  eu_ted: 'EU TED',
  world_bank: 'World Bank',
  afdb: 'AfDB',
  ungm: 'UNGM',
  escom: 'ESCOM',
  mra: 'MRA',
};

const sourceBadge = `source-${tender.source}`;
---

<a href={`/tender/${tender.slug}/`} class="glass-card block p-5">
  <div class="flex items-start justify-between gap-3">
    <div class="flex-1 min-w-0">
      <!-- Status + Source badges -->
      <div class="flex flex-wrap items-center gap-2 mb-2">
        <span class:list={["inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium", statusClass]}>
          {statusLabel}
        </span>
        <span class:list={["inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium", sourceBadge]}>
          {sourceNames[tender.source] || tender.source}
        </span>
        {tender.category && (
          <span class="inline-flex items-center rounded-full bg-bg px-2.5 py-0.5 text-xs font-medium text-muted border border-border">
            {tender.category}
          </span>
        )}
      </div>

      <!-- Title -->
      <h3 class="text-base font-semibold text-text line-clamp-2 group-hover:text-primary transition-colors">
        {tender.title}
      </h3>

      <!-- Entity -->
      <p class="mt-1 text-sm text-muted">
        {tender.procuring_entity}
      </p>

      <!-- Meta row -->
      <div class="mt-3 flex flex-wrap items-center gap-x-4 gap-y-1 text-xs text-muted">
        {tender.closing_date && (
          <span class="flex items-center gap-1">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M5.75 2a.75.75 0 01.75.75V4h7V2.75a.75.75 0 011.5 0V4h.25A2.75 2.75 0 0118 6.75v8.5A2.75 2.75 0 0115.25 18H4.75A2.75 2.75 0 012 15.25v-8.5A2.75 2.75 0 014.75 4H5V2.75A.75.75 0 015.75 2z" clip-rule="evenodd"/>
            </svg>
            Closes {formatDate(tender.closing_date)}
          </span>
        )}
        {tender.region && (
          <span class="flex items-center gap-1">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M9.69 18.933l.003.001C9.89 19.02 10 19 10 19s.11.02.308-.066l.002-.001.006-.003.018-.008a5.741 5.741 0 00.281-.14c.186-.096.446-.24.757-.433.62-.384 1.445-.966 2.274-1.765C15.302 14.988 17 12.493 17 9A7 7 0 103 9c0 3.492 1.698 5.988 3.355 7.584a13.731 13.731 0 002.274 1.765 11.842 11.842 0 00.976.544l.062.029.018.008.006.003zM10 11.25a2.25 2.25 0 100-4.5 2.25 2.25 0 000 4.5z" clip-rule="evenodd"/>
            </svg>
            {tender.city || tender.region}
          </span>
        )}
        {tender.reference_number && (
          <span class="text-muted/60">
            Ref: {tender.reference_number}
          </span>
        )}
      </div>
    </div>
  </div>
</a>
