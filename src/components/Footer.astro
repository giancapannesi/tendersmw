---
const currentYear = new Date().getFullYear();

const categoryLinks = [
  { name: 'Goods & Supplies', href: '/category/goods/' },
  { name: 'Construction & Works', href: '/category/works/' },
  { name: 'Consulting Services', href: '/category/consulting/' },
  { name: 'IT & Technology', href: '/category/technology/' },
  { name: 'General Services', href: '/category/services/' },
];

const resourceLinks = [
  { name: 'About', href: '/about/' },
  { name: 'How to Bid', href: '/guides/how-to-bid-on-tenders-in-malawi/' },
  { name: 'PPDA Guide', href: '/guides/ppda-procurement-guide/' },
  { name: 'Privacy Policy', href: '/privacy/' },
  { name: 'Terms of Service', href: '/terms/' },
  { name: 'Disclaimer', href: '/disclaimer/' },
  { name: 'Disclosure', href: '/disclosure/' },
  { name: 'Editorial Policy', href: '/editorial-policy/' },
  { name: 'Methodology', href: '/methodology/' },
  { name: 'Accessibility', href: '/accessibility/' },
  { name: 'Do Not Sell', href: '/do-not-sell/' },
];

const sourceLinks = [
  { name: 'PPDA Tenders', href: '/source/ppda/' },
  { name: 'MANEPS', href: '/source/maneps/' },
  { name: 'World Bank', href: '/source/world_bank/' },
  { name: 'EU TED', href: '/source/eu_ted/' },
  { name: 'UN Procurement', href: '/source/ungm/' },
];
---

<footer class="border-t border-border bg-bg-alt">
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-4">
      <!-- Brand -->
      <div class="sm:col-span-2 lg:col-span-1">
        <a href="/" class="flex items-center gap-2 text-primary font-bold text-xl">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
            <polyline points="14 2 14 8 20 8"/>
            <line x1="16" y1="13" x2="8" y2="13"/>
            <line x1="16" y1="17" x2="8" y2="17"/>
            <polyline points="10 9 9 9 8 9"/>
          </svg>
          <span>TendersMW</span>
        </a>
        <p class="mt-3 text-sm text-muted leading-relaxed">
          Malawi's procurement intelligence platform. Find government and development tenders from PPDA, MANEPS, World Bank, African Development Bank, and more.
        </p>
      </div>

      <!-- Categories -->
      <div>
        <h3 class="text-sm font-semibold text-text uppercase tracking-wider">Categories</h3>
        <ul class="mt-4 space-y-3">
          {categoryLinks.map(link => (
            <li>
              <a href={link.href} class="text-sm text-muted hover:text-primary transition-colors">
                {link.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Sources -->
      <div>
        <h3 class="text-sm font-semibold text-text uppercase tracking-wider">Sources</h3>
        <ul class="mt-4 space-y-3">
          {sourceLinks.map(link => (
            <li>
              <a href={link.href} class="text-sm text-muted hover:text-primary transition-colors">
                {link.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Resources -->
      <div>
        <h3 class="text-sm font-semibold text-text uppercase tracking-wider">Resources</h3>
        <ul class="mt-4 space-y-3">
          {resourceLinks.map(link => (
            <li>
              <a href={link.href} class="text-sm text-muted hover:text-primary transition-colors">
                {link.name}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="mt-10 flex flex-col items-center justify-between gap-4 border-t border-border pt-8 sm:flex-row">
      <p class="text-xs text-muted">
        &copy; {currentYear} TendersMW. All rights reserved. Data sourced from PPDA, MANEPS, and international development organizations.
      </p>
      <div class="flex flex-wrap items-center gap-x-4 gap-y-1">
        <a href="/privacy/" class="text-xs text-muted hover:text-primary transition-colors">Privacy</a>
        <span class="text-border">|</span>
        <a href="/terms/" class="text-xs text-muted hover:text-primary transition-colors">Terms</a>
        <span class="text-border">|</span>
        <a href="/disclaimer/" class="text-xs text-muted hover:text-primary transition-colors">Disclaimer</a>
        <span class="text-border">|</span>
        <a href="/disclosure/" class="text-xs text-muted hover:text-primary transition-colors">Disclosure</a>
        <span class="text-border">|</span>
        <a href="/accessibility/" class="text-xs text-muted hover:text-primary transition-colors">Accessibility</a>
        <span class="text-border">|</span>
        <a href="/do-not-sell/" class="text-xs text-muted hover:text-primary transition-colors">Do Not Sell</a>
      </div>
    </div>
  </div>
</footer>
